{
  "name": "linkgrow",
  "version": "1.0.0",
  "description": "Dashboard interativa para métricas de engajamento do LinkedIn para Falden Software",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "install:all": "npm install && npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install",
    "test": "concurrently \"npm run test:frontend\" \"npm run test:backend\"",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "build": "concurrently \"npm run build:frontend\" \"npm run build:backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcos-Devops/linkgrow.git"
  },
  "keywords": ["linkedin", "dashboard", "analytics", "react", "nodejs", "express"],
  "author": "Falden Software",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Marcos-Devops/linkgrow/issues"
  },
  "homepage": "https://github.com/Marcos-Devops/linkgrow#readme",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
